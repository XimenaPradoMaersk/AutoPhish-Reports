"""
Reporting Metrics Module

This script calculates reporting metrics from phishing campaign data:
- Number of reported users
- Reporting rate

This represents logic originally implemented in a Dify code node.
"""

import csv


def extract_reported_users(file_path):
    """
    Extract unique reported users from a CSV file

    :param file_path: Path to CSV file
    :return: Set of unique reporter emails/users
    """

    reported_users_set = set()

    with open(file_path, "r", encoding="utf-8", errors="ignore") as f:
        csv_reader = csv.reader(f)
        rows = list(csv_reader)

    if len(rows) < 2:
        return reported_users_set

    headers = rows[0]

    reporter_idx = None
    reporter_email_idx = None

    # Detect relevant columns
    for i, col in enumerate(headers):
        col_clean = str(col).strip()

        if col_clean == "Reporter":
            reporter_idx = i
        if col_clean == "Reporter Address":
            reporter_email_idx = i

    # Extract unique users
    for row in rows[1:]:
        try:
            if reporter_email_idx is not None and reporter_email_idx < len(row):
                value = row[reporter_email_idx]
            elif reporter_idx is not None and reporter_idx < len(row):
                value = row[reporter_idx]
            else:
                value = None

            if value:
                reported_users_set.add(str(value).strip().lower())

        except Exception:
            continue

    return reported_users_set


def calculate_reporting_metrics(file_path, total_users):
    """
    Calculate reporting metrics

    :param file_path: Path to CSV file
    :param total_users: Total number of users from simulation
    :return: Dictionary with reporting metrics
    """

    reported_users_set = extract_reported_users(file_path)

    reported_users = len(reported_users_set)
    total_users = int(total_users)

    reporting_rate = (reported_users / total_users) * 100 if total_users > 0 else 0

    return {
        "reported_users": reported_users,
        "total_users": total_users,
        "reporting_rate": round(reporting_rate, 2)
    }


def main():
    # ✅ Example usage
    file_path = "sample_reporting_data.csv"
    total_users = 100  # Replace with your actual value

    results = calculate_reporting_metrics(file_path, total_users)

    print("✅ Reported Users:", results["reported_users"])
    print("✅ Total Users:", results["total_users"])
    print("✅ Reporting Rate:", f"{results['reporting_rate']}%")


if __name__ == "__main__":
    main()
